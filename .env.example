# ─── Docker / Compose Environment Variables ───────────────────────────────────

# Node environment: development | production
NODE_ENV=development

# MongoDB root credentials (used by Docker Compose)
MONGO_ROOT_USER=admin
MONGO_ROOT_PASS=changeme_strong_password

# JWT — CHANGE THIS IN PRODUCTION!
JWT_SECRET=replace_this_with_a_very_long_random_string_min_32_chars
JWT_EXPIRE=30d

# Frontend URL (for CORS — no trailing slash)
FRONTEND_URL=http://localhost

# Cloudinary image upload (optional — leave empty to skip)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
